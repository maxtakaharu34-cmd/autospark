# Existing — public generate endpoint
ANTHROPIC_API_KEY=your_key_here
ALLOWED_ORIGINS=http://localhost:3000
GENERATE_RATE_LIMIT_MAX=5
GENERATE_RATE_LIMIT_WINDOW_MS=60000

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated emails allowed to access /dashboard
ALLOWED_ADMIN_EMAILS=

# X (Twitter) — OAuth 1.0a
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=
X_OAUTH_CALLBACK_URL=http://localhost:3000/api/x/callback

# Meta (Instagram / Facebook Graph API)
META_APP_ID=
META_APP_SECRET=
META_OAUTH_CALLBACK_URL=http://localhost:3000/api/instagram/callback

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ENTERPRISE=

# Notifications
SLACK_WEBHOOK_URL=
SLACK_ERROR_WEBHOOK_URL=
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Vercel Cron protection (Bearer token)
CRON_SECRET=

# AES-256-GCM key (32 bytes hex = 64 chars) — used to encrypt OAuth tokens at rest
ENCRYPTION_KEY=
